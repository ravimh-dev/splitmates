{
  "name": "splitmate-backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p . && node scripts/build-and-zip.js backend",
    "build:frontend": "npm --prefix frontend run build && node scripts/build-and-zip.js frontend",
    "start": "npm run build && node dist/app.js",
    "migrate": "npx ts-node src/db/init.ts",
    "db:init": "npx ts-node src/db/init.ts",
    "db:seed": "npx ts-node src/db/sample-data.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.10.0",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.5.1",
    "@types/pg": "^8.20.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6",
    "vitest": "^1.4.5",
    "archiver": "^5.3.1"
  }
}
