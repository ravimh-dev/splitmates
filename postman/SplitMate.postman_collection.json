{
  "info": {
    "name": "SplitMate API",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "description": "Postman collection for SplitMate expense-splitting backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000/api/v1"
    },
    {
      "key": "jwt_token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Current User Profile",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users/profile",
              "host": ["{{baseUrl}}"],
              "path": ["users", "profile"]
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Updated\",\n  \"avatar_url\": \"https://example.com/avatar.png\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/profile",
              "host": ["{{baseUrl}}"],
              "path": ["users", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "Groups",
      "item": [
        {
          "name": "Create Group",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Trip to Goa\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/groups",
              "host": ["{{baseUrl}}"],
              "path": ["groups"]
            }
          }
        },
        {
          "name": "Get Group Balances",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/groups/{{groupId}}/balances",
              "host": ["{{baseUrl}}"],
              "path": ["groups", "{{groupId}}", "balances"]
            }
          }
        },
        {
          "name": "Simplify Group Debts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/groups/{{groupId}}/settlements/simplify",
              "host": ["{{baseUrl}}"],
              "path": [
                "groups",
                "{{groupId}}",
                "settlements",
                "simplify"
              ]
            }
          }
        },
        {
          "name": "Export Group Statement",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/groups/{{groupId}}/export?format=csv",
              "host": ["{{baseUrl}}"],
              "path": [
                "groups",
                "{{groupId}}",
                "export"
              ],
              "query": [
                {
                  "key": "format",
                  "value": "csv"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Expenses",
      "item": [
        {
          "name": "Create Expense",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"group_id\": \"group123\",\n  \"paid_by\": \"user123\",\n  \"amount\": 1000,\n  \"split_type\": \"EQUAL\",\n  \"splits\": [\n    {\n      \"user_id\": \"user123\",\n      \"amount\": 500\n    },\n    {\n      \"user_id\": \"user456\",\n      \"amount\": 500\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/expenses",
              "host": ["{{baseUrl}}"],
              "path": ["expenses"]
            }
          }
        }
      ]
    },
    {
      "name": "Settlements",
      "item": [
        {
          "name": "Create Settlement",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"group_id\": \"group123\",\n  \"from_user_id\": \"user123\",\n  \"to_user_id\": \"user456\",\n  \"amount\": 500\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/settlements",
              "host": ["{{baseUrl}}"],
              "path": ["settlements"]
            }
          }
        },
        {
          "name": "Mark Settlement Paid",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/settlements/{{settlementId}}/pay",
              "host": ["{{baseUrl}}"],
              "path": ["settlements", "{{settlementId}}", "pay"]
            }
          }
        }
      ]
    },
    {
      "name": "Activities",
      "item": [
        {
          "name": "List Group Activities",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/activities/groups/{{groupId}}?limit=20&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["activities", "groups", "{{groupId}}"],
              "query": [
                {
                  "key": "limit",
                  "value": "20",
                  "description": "Max number of items to return"
                },
                {
                  "key": "offset",
                  "value": "0",
                  "description": "Number of items to skip"
                },
                {
                  "key": "type",
                  "value": "expense_added",
                  "disabled": true,
                  "description": "Filter by activity type"
                },
                {
                  "key": "actorId",
                  "value": "",
                  "disabled": true,
                  "description": "Filter by user ID of actor"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
